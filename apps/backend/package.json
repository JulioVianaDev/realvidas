{
  "name": "@realvidas/backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build -b swc",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "CHOKIDAR_USEPOLLING=true nest start -b swc -w",
    "dev": "DOTENV_CONFIG_PATH=../../.env CHOKIDAR_USEPOLLING=true NODE_OPTIONS='--experimental-require-module -r dotenv/config' nest start -b swc -w",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --passWithNoTests --testPathPattern=\"modules/.*/services/.*\\.spec\\.ts$\"",
    "test:file": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --passWithNoTests --coverage --collectCoverageFrom=\"modules/**/services/*service.ts\"",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed": "ts-node  -r tsconfig-paths/register  src/tools.ts",
    "db:run:main": "ts-node -r dotenv/config src/infra/postgres-databases/run-migrations.ts",
    "db:run:tenant": "ts-node -r dotenv/config src/infra/postgres-databases/run-tenant-migrations-all.ts",
    "db:generate:main": "ts-node -r dotenv/config src/infra/postgres-databases/generate-migrations.ts dev public",
    "db:generate:tenant:all": "ts-node -r dotenv/config src/infra/postgres-databases/generate-migrations.ts dev tenanted-all"
  },
  "dependencies": {
    "@realvidas/types": "*",
    "@realvidas/email-templates": "*",
    "@dalet-oss/lexorank": "^1.1.2",
    "@elastic/elasticsearch": "^8.17.1",
    "@fastify/multipart": "^9.0.2",
    "@fastify/static": "^7.0.4",
    "@nest-lab/fastify-multer": "^1.3.0",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^10.4.15",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/nodemailer": "^6.4.17",
    "abacatepay-nodejs-sdk": "^1.6.0",
    "amqplib": "^0.10.7",
    "axios": "^1.8.4",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.73.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parser": "^3.2.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.5.0",
    "google-auth-library": "^10.4.2",
    "googleapis": "^144.0.0",
    "groupmq": "^1.1.0",
    "ioredis": "^5.6.0",
    "nestjs-cls": "^6.2.0",
    "nodemailer": "^7.0.13",
    "papaparse": "^5.5.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "redis": "^5.9.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "stripe": "^22.0.2",
    "typeorm": "^0.3.28",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@swc/cli": "^0.5.2",
    "@swc/core": "^1.10.1",
    "@swc/jest": "^0.2.39",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "@swc/jest",
        {
          "jsc": {
            "parser": {
              "syntax": "typescript",
              "decorators": true
            },
            "transform": {
              "decoratorMetadata": true,
              "legacyDecorator": true
            }
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1",
      "^@global-types/(.*)$": "<rootDir>/../../../packages/types/dist/$1",
      "^@email-templates/(.*)$": "<rootDir>/../../../packages/email-templates/dist/$1"
    }
  }
}
