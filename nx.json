{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/tsconfig.json"],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/test/**/*"
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production"],
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "continuous": true,
      "cache": false
    },
    "lint": {
      "inputs": ["default"],
      "cache": true
    },
    "test": {
      "inputs": ["default"],
      "cache": true
    }
  },
  "defaultBase": "origin/main"
}
