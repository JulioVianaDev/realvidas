{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "@realvidas/frontend",
    "sourceRoot": "apps/frontend/src",
    "projectType": "application",
    "tags": ["scope:frontend", "lang:ts"],
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run build",
                "cwd": "apps/frontend"
            },
            "inputs": ["production", "^production"],
            "outputs": ["{projectRoot}/build"],
            "cache": true
        },
        "dev": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run dev",
                "cwd": "apps/frontend"
            },
            "continuous": true,
            "cache": false
        },
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run lint",
                "cwd": "apps/frontend"
            },
            "cache": true
        }
    },
    "implicitDependencies": [
        "@realvidas/types",
        "@realvidas/email-templates"
    ]
}
