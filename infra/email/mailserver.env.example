OVERRIDE_HOSTNAME=mail.realvidas.io
DOMAINNAME=realvidas.io
POSTMASTER_ADDRESS=contact@realvidas.io
LOG_LEVEL=info
SMTP_ONLY=0
SSL_TYPE=letsencrypt
ENABLE_SPAMASSASSIN=1
SPAMASSASSIN_SPAM_TO_JUNK=1
ENABLE_CLAMAV=0
ENABLE_FAIL2BAN=1
ENABLE_POSTFIX_VIRTUAL_TRANSPORT=0
POSTFIX_INET_PROTOCOLS=ipv4
ENABLE_DOVECOT=1
ENABLE_AMAVIS=1
ENABLE_OPENDKIM=1
ENABLE_OPENDMARC=1
ENABLE_POLICYD_SPF=1
