#nestjs
JWT_SECRET=TomateBaoDemais
BCRYPT_SALT_ROUNDS=10

#frontend
NESTJS_URL=http://localhost:8080/v1

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mydb
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mydb

# apps/whatsmeow (Meow bridge) — read from this same root `.env` locally and in Docker Compose
# Local `go run`: DB_URL uses localhost. In Docker, use hostname `db` (Compose service name).
DB_DRIVER=postgres
DB_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable
# DB_URL=postgres://postgres:postgres@db:5432/postgres?sslmode=disable
EASY_ZAP_WEBHOOK_URL=http://localhost:4444

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
# Optional: full URI for apps/whatsmeow (overrides USER/PASSWORD/HOST/PORT when set).
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# In Docker Compose, whatsapp_realvidas sets RABBITMQ_HOST=rabbitmq so the bridge reaches the broker.

# Bridge waits for AMQP before starting HTTP (skip only if you run without RabbitMQ).
# RABBITMQ_SKIP_STARTUP_WAIT=true
# RABBITMQ_STARTUP_MAX_WAIT=3m
# RABBITMQ_STARTUP_RETRY_INTERVAL=2s

# Must match Nest apps/backend WEBHOOK_RABBIT_TOPOLOGY: per_instance (fanout queue.{instanceKey}) or topic (exchange webhooks).
# WEBHOOK_RABBIT_TOPOLOGY=per_instance

#Redis 
REDIS_HOST=localhost
REDIS_PORT=6379
NEST_PORT= 8080

# NestJS
JWT_SECRET=TomateIsGood
API_URL=http://localhost:8080/v1
BCRYPT_SALT_ROUNDS=10
# API_URL= http://localhost:8082/v1/
# NEST_URL=  http://localhost:8082/v1/
# RAILS_URL=  http://localhost:8081/v1/

ELASTIC_SEARCH_URL = http://localhost:9200

SOCKET_URL=http://localhost:8080

#ips
LOCAL_CONNECTION_INTERFACE_NAME="Wi-Fi"
LOCAL_CONNECTION_IPV4_SEARCH="192.xxx.xx.xx"

